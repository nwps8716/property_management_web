### Component Patterns

#### 1. Server Components (Default)
- Fetch data directly from Supabase
- Access user session via `createClient()`
- Handle async data fetching
- Example: `Sidebar.tsx`, `DashboardPage`

```typescript
// Example Server Component pattern
import { createClient } from '@/utils/supabase/server'

export default async function Component() {
  const supabase = await createClient()
  const { data: { user } } = await supabase.auth.getUser()
  const { data: profile } = await supabase
    .from('profiles')
    .select('*')
    .eq('id', user?.id)
    .single()
  
  return <div>{profile?.name}</div>
}
```

#### 2. Client Components (Explicit with `'use client'`)
- Used for interactive UI elements
- Handle form submissions with `useFormStatus()`
- Manage local state with `useState()`
- Self-fetch data when needed (InviteForm pattern)

```typescript
'use client'

import { useState, useEffect } from 'react'
import { useFormStatus } from 'react-dom'

// Self-fetching component pattern
export function InviteForm() {
  const [companies, setCompanies] = useState<Company[]>([])
  const [loading, setLoading] = useState(true)
  
  useEffect(() => {
    fetch('/api/companies')
      .then(res => res.json())
      .then(data => setCompanies(data.companies))
      .finally(() => setLoading(false))
  }, [])
  
  if (loading) return <Skeleton />
  return <FormUI companies={companies} />
}
```

#### 3. Server Actions (Marked with `'use server'`)
- Handle form submissions server-side
- Perform database mutations
- Use `revalidatePath()` for cache invalidation
- Return structured response objects (`ActionState` interface)

```typescript
'use server'

import { revalidatePath } from 'next/cache'

export interface ActionState {
  success: boolean;
  message: string;
}

export async function actionName(formData: FormData): Promise<ActionState> {
  // Process form data
  revalidatePath('/path')
  return { success: true, message: 'Success message' }
}
```

### API Routes Pattern

```typescript
// app/api/companies/route.ts
import { supabaseAdmin } from '@/utils/supabase/admin'
import { NextResponse } from 'next/server'

export async function GET() {
  const { data: companies, error } = await supabaseAdmin
    .from('companies')
    .select('id, name')
    .order('name')

  if (error) {
    return NextResponse.json(
      { error: 'Failed to fetch companies' },
      { status: 500 }
    )
  }

  return NextResponse.json({ companies: companies || [] })
}
```

### Page Transition Pattern

```typescript
// components/ui/PageTransitionProvider.tsx
'use client'

import { useEffect, useState } from 'react'
import { usePathname } from 'next/navigation'

export function PageTransitionProvider({ children }) {
  const [isTransitioning, setIsTransitioning] = useState(false)
  const pathname = usePathname()

  useEffect(() => {
    setIsTransitioning(true)
    const timer = setTimeout(() => setIsTransitioning(false), 150)
    return () => clearTimeout(timer)
  }, [pathname])

  return (
    <div className={`transition-all duration-300 ease-in-out ${
      isTransitioning 
        ? 'opacity-0 transform translate-y-2' 
        : 'opacity-100 transform translate-y-0'
    }`}>
      {children}
    </div>
  )
}
```

