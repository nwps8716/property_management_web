### Adding New Server Actions

1. **Define Return Type**:
   ```typescript
   export interface ActionState {
     success: boolean;
     message: string;
   }
   ```

2. **Create Action Function**:
   ```typescript
   'use server'
   
   export async function newAction(formData: FormData): Promise<ActionState> {
     // Validate input
     const field = formData.get('fieldName') as string
     if (!field) {
       return { success: false, message: '欄位必填' }
     }
     
     // Perform operation
     const { error } = await supabaseAdmin.from('table').insert({ field })
     
     if (error) {
       return { success: false, message: error.message }
     }
     
     // Invalidate cache
     revalidatePath('/relevant-path')
     
     return { success: true, message: '操作成功' }
   }
   ```

